# Vite (browser) — required for `src/lib/supabase.ts`.
# Copy to `.env` or `.env.local` for local dev. Hosted builds must inject the same values
# for the Supabase project where Edge functions are deployed.
#
# Project alignment: `VITE_SUPABASE_URL` host must be `https://<project-ref>.supabase.co`
# for the same project you deploy with `supabase functions deploy` / Dashboard.
# See docs/GMAIL_ROLLOUT_RUNBOOK.md §0.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_from_project_api_settings

# Operator Ana (dashboard) — progressive streaming vs one-shot reply
#
# SupportAssistantWidget only uses fetch + SSE when the Vite flag below is exactly "true". Otherwise it uses
# supabase.functions.invoke (single JSON) — replies appear all at once on localhost.
#
# Localhost: add to repo-root `.env` or `.env.local`, then restart Vite (`npm run dev`):
#   VITE_OPERATOR_ASSISTANT_STREAMING_V1=true
#
# Hosted Edge (same Supabase project as VITE_SUPABASE_URL): Dashboard → Edge Functions → Secrets:
#   OPERATOR_ASSISTANT_STREAMING_V1=true
# If the client flag is on but this secret is off, the function still returns JSON and the stream parser can fail.
#
# supabase functions serve: pass both in your `--env-file` if you test functions locally.
# VITE_OPERATOR_ASSISTANT_STREAMING_V1=

# Optional: `[Ana stream] …` console timing logs in the operator widget (also on in Vite dev without this).
# Edge (optional): set secret `OPERATOR_ASSISTANT_STREAM_DEBUG=true` for one JSON log per stream with tokenSseEventCount.
# VITE_ANA_STREAM_DEBUG=

# Operator Ana LLM provider (Supabase Edge secret for `operator-studio-assistant`, or env for `supabase functions serve`).
# Default: OpenAI — requires OPENAI_API_KEY (existing). Model defaults to gpt-4o-mini unless ANA_LLM_MODEL is set.
# Optional: ANA_LLM_PROVIDER=google and GEMINI_API_KEY (Google AI Studio / Gemini API key). Default Gemini model: gemini-2.5-flash.
# With the operator widget (supabase client), Gemini uses the same bounded read-only operator_lookup_* tool round as OpenAI; both return the same JSON reply shape.
# ANA_LLM_PROVIDER=openai
# ANA_LLM_MODEL=
# GEMINI_API_KEY=
